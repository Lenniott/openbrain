# Copy this to .env and fill in your values

### Core API
APP_HOST=http://192.168.x.x        # Your Umbrel LAN IP
APP_PORT=7788

### Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=openbrain
POSTGRES_USER=openbrain
POSTGRES_PASSWORD=change_me

### Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=openbrain
# QDRANT_API_KEY=                  # Leave blank for no auth (self-hosted)

### Minio / S3
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=openbrain
S3_SECRET_ACCESS_KEY=change_me
S3_BUCKET_FILES=files

### Embedding — point at your Ollama instance
EMBEDDING_BASE_URL=http://192.168.x.x:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_SECONDS=15

### Transcription — point at your Whisper instance (if using)
WHISPER_BASE_URL=http://192.168.x.x:7777
WHISPER_MODEL=medium
WHISPER_TIMEOUT_SECONDS=60

### Chunking
CHUNK_SIZE=600
CHUNK_OVERLAP=100
CONFIDENCE_THRESHOLD=0.8

### Misc
ENVIRONMENT=production
